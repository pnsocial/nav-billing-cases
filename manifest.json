{
  "manifest_version": 3,
  "name": "GCP Billing Support Navigator",
  "version": "1.0",
  "description": "Adds a 'Support Case' item to the GCP Billing navigation menu.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://console.cloud.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://console.cloud.google.com/billing/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
